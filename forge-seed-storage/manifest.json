{
  "id": "forge-seed-storage",
  "name": "Forge: Seed Storage v2",
  "description": "Forge orchestrator — clean-room rebuild of Discord→Neo4j ingestion pipeline. Tier-0→Tier-1→Tier-2 agents sequentially, pushes to feat/v2-rebuild, opens PR.",
  "type": "agent",
  "owner": "wyler-zahm",
  "source": {
    "type": "git",
    "repo": "https://github.com/Cruse-Control/ant-keeper-tasks.git",
    "ref": "main",
    "working_dir": "forge-seed-storage/"
  },
  "backend": "hermes",
  "entry_point": "prompt.md",
  "credentials": {
    "anthropic": "ANTHROPIC_API_KEY",
    "github-pat": "GITHUB_TOKEN"
  },
  "backend_config": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "max_turns": 500
  },
  "resources": {
    "cpu": "2000m",
    "memory": "4Gi"
  },
  "databases": [],
  "can_trigger": [],
  "alert_channels": [
    {
      "channel": "ops-alerts",
      "provider": "discord"
    }
  ],
  "dns_passthrough": [],
  "schedule": "23:59",
  "timezone": "America/Denver",
  "run_if_missed": false,
  "enabled": true
}
